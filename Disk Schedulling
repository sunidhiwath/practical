#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, i, head, total_movement = 0;

    printf("Enter number of disk requests: ");
    scanf("%d", &n);

    int req[n], visited[n];

    printf("Enter the disk requests:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &req[i]);
        visited[i] = 0;
    }

    printf("Enter initial head position: ");
    scanf("%d", &head);

    // ---------------- FCFS ----------------
    total_movement = 0;
    int current = head;

    printf("\n--- FCFS Disk Scheduling ---\n");
    for(i = 0; i < n; i++) {
        printf("Move from %d to %d\n", current, req[i]);
        total_movement += abs(req[i] - current);
        current = req[i];
    }

    printf("Total Head Movement (FCFS): %d\n", total_movement);

    // ---------------- SSTF ----------------
    total_movement = 0;
    current = head;

    printf("\n--- SSTF Disk Scheduling ---\n");

    for(i = 0; i < n; i++) {
        int min = 9999, index = -1;

        for(int j = 0; j < n; j++) {
            if(!visited[j]) {
                int dist = abs(req[j] - current);
                if(dist < min) {
                    min = dist;
                    index = j;
                }
            }
        }

        visited[index] = 1;
        printf("Move from %d to %d\n", current, req[index]);
        total_movement += abs(req[index] - current);
        current = req[index];
    }

    printf("Total Head Movement (SSTF): %d\n", total_movement);

    return 0;
}

