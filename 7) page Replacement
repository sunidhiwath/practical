#include <stdio.h>

int main() {
    int frames, pages;

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    int ref[pages];
    printf("Enter reference string:\n");
    for(int i = 0; i < pages; i++) {
        scanf("%d", &ref[i]);
    }

    int frame[frames];
    int i, j, k;
    int flag, faults = 0, hits = 0;
    int index = 0;

    // Initialize frames with -1
    for(i = 0; i < frames; i++) {
        frame[i] = -1;
    }

    printf("\nPage Replacement Process:\n");

    for(i = 0; i < pages; i++) {
        flag = 0;

        // Check if page is already in frame (HIT)
        for(j = 0; j < frames; j++) {
            if(frame[j] == ref[i]) {
                hits++;
                flag = 1;
                break;
            }
        }

        // If not found (MISS)
        if(flag == 0) {
            frame[index] = ref[i];
            index = (index + 1) % frames;
            faults++;
        }

        // Print current frame status
        printf("Page %d -> ", ref[i]);
        for(k = 0; k < frames; k++) {
            if(frame[k] != -1)
                printf("%d ", frame[k]);
            else
                printf("- ");
        }

        if(flag)
            printf("(HIT)\n");
        else
            printf("(FAULT)\n");
    }

    float hit_ratio = (float)hits / pages;
    float miss_ratio = (float)faults / pages;

    printf("\nTotal Page Faults = %d\n", faults);
    printf("Total Page Hits = %d\n", hits);
    printf("Hit Ratio = %.2f\n", hit_ratio);
    printf("Miss Ratio = %.2f\n", miss_ratio);

    return 0;
}

